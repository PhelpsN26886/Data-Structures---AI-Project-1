    // =========================================================================
    //  Product record stored in both hashtables
    // =========================================================================
    public class Product
    {
        public string Barcode { get; init; }
        public string Name { get; init; }
        public decimal Price { get; init; }

        public Product(string barcode, string name, decimal price)
        {
            Barcode = barcode;
            Name = name;
            Price = price;
        }

        public override string ToString() =>
            $"{Name,-38} | {Barcode} | ${Price:F2}";
    }

    // =========================================================================
    //  Lookup result — returned by both hashtable types
    // =========================================================================
    public class LookupResult
    {
        public bool Found { get; init; }
        public Product? Item { get; init; }
        public int Comparisons { get; init; }   // number of key comparisons
        public long ElapsedNs { get; init; }
        public List<string> Steps { get; init; } = new();

        public override string ToString()
        {
            var sb = new StringBuilder();
            sb.AppendLine(Found
                ? $"  ✓ FOUND  : {Item}"
                : "  ✗ NOT FOUND");
            sb.AppendLine($"  Comparisons : {Comparisons}");
            sb.AppendLine($"  Elapsed     : {ElapsedNs} ns");
            foreach (var s in Steps) sb.AppendLine($"    {s}");
            return sb.ToString();
        }
    }

    // =========================================================================
    //  HASHTABLE 1 — Separate Chaining
    //  Each bucket is a linked list (List<Product>).
    //  Collisions simply append to the chain — the table never fills up.
    //
    //  Avg comparisons (successful)   ≈ 1 + λ/2
    //  Avg comparisons (unsuccessful) ≈ λ          where λ = n / capacity
    // =========================================================================
    public class SeparateChainingHashTable
    {
        private readonly List<Product>[] _buckets;
        private int _count;

        public int Capacity => _buckets.Length;
        public int Count => _count;
        public double LoadFactor => (double)_count / Capacity;

        public SeparateChainingHashTable(int capacity)
        {
            if (capacity < 1) throw new ArgumentOutOfRangeException(nameof(capacity));
            _buckets = new List<Product>[capacity];
            for (int i = 0; i < capacity; i++)
                _buckets[i] = new List<Product>();
        }

        // Polynomial rolling hash on the barcode string
        private int Hash(string barcode)
        {
            unchecked
            {
                int h = 0;
                foreach (char c in barcode)
                    h = h * 31 + c;
                return Math.Abs(h) % Capacity;
            }
        }

        // ── Insert ──────────────────────────────────────────────────────────
        public void Insert(Product product)
        {
            int idx = Hash(product.Barcode);
            // Replace if barcode already exists
            for (int i = 0; i < _buckets[idx].Count; i++)
            {
                if (_buckets[idx][i].Barcode == product.Barcode)
                {
                    _buckets[idx][i] = product;
                    return;
                }
            }
            _buckets[idx].Add(product);
            _count++;
        }

        // ── Lookup ──────────────────────────────────────────────────────────
        public LookupResult Lookup(string barcode)
        {
            var sw = Stopwatch.StartNew();
            int idx = Hash(barcode);
            var chain = _buckets[idx];
            var steps = new List<string>();
            int compares = 0;

            steps.Add($"Hash(\"{barcode}\") → bucket {idx}  (chain length = {chain.Count})");

            for (int i = 0; i < chain.Count; i++)
            {
                compares++;
                if (chain[i].Barcode == barcode)
                {
                    sw.Stop();
                    steps.Add($"  [{i}] {chain[i].Barcode} → MATCH ✓");
                    return new LookupResult
                    {
                        Found = true,
                        Item = chain[i],
                        Comparisons = compares,
                        ElapsedNs = sw.ElapsedTicks * 1_000_000_000L / Stopwatch.Frequency,
                        Steps = steps
                    };
                }
                steps.Add($"  [{i}] {chain[i].Barcode} → no match");
            }

            sw.Stop();
            steps.Add(chain.Count == 0 ? "  Bucket empty → NOT FOUND" : "  End of chain → NOT FOUND");
            return new LookupResult
            {
                Found = false,
                Comparisons = compares,
                ElapsedNs = sw.ElapsedTicks * 1_000_000_000L / Stopwatch.Frequency,
                Steps = steps
            };
        }

        // ── Delete ──────────────────────────────────────────────────────────
        public bool Delete(string barcode)
        {
            int idx = Hash(barcode);
            var chain = _buckets[idx];
            for (int i = 0; i < chain.Count; i++)
            {
                if (chain[i].Barcode == barcode)
                {
                    chain.RemoveAt(i);
                    _count--;
                    return true;
                }
            }
            return false;
        }

        // ── Diagnostics ─────────────────────────────────────────────────────
        public HashTableStats GetStats()
        {
            int maxChain = _buckets.Max(b => b.Count);
            int empties = _buckets.Count(b => b.Count == 0);
            int collisions = _buckets.Sum(b => Math.Max(0, b.Count - 1));
            double avgChain = _count == 0 ? 0 : (double)_count / _buckets.Count(b => b.Count > 0);

            return new HashTableStats
            {
                Type = "Separate Chaining",
                Capacity = Capacity,
                Count = _count,
                LoadFactor = LoadFactor,
                EmptySlots = empties,
                Collisions = collisions,
                MaxCluster = maxChain,
                AvgChainLength = Math.Round(avgChain, 2),
                TheoreticalAvgProbesFound = Math.Round(1 + LoadFactor / 2.0, 3),
                TheoreticalAvgProbesMiss = Math.Round(LoadFactor, 3)
            };
        }

        public void PrintBuckets(int maxBuckets = 20)
        {
            Console.WriteLine($"\n  {"IDX",-5} {"CHAIN CONTENTS",-60} {"LEN",-4}");
            Console.WriteLine($"  {new string('─', 72)}");
            int shown = Math.Min(Capacity, maxBuckets);
            for (int i = 0; i < shown; i++)
            {
                var items = _buckets[i].Select(p => p.Barcode[^6..]);
                string content = _buckets[i].Count == 0
                    ? "(empty)"
                    : string.Join(" → ", items);
                Console.WriteLine($"  [{i,3}]  {content,-60} {_buckets[i].Count}");
            }
            if (shown < Capacity)
                Console.WriteLine($"  ... ({Capacity - shown} more buckets not shown)");
        }
    }

    // =========================================================================
    //  HASHTABLE 2 — Linear Probing (Open Addressing)
    //  All entries live in a flat array. On collision, step forward +1 until
    //  an empty slot. Deletions use a DELETED tombstone to keep probe chains intact.
    //
    //  Avg comparisons (successful)   ≈ ½ · (1 + 1/(1−λ))
    //  Avg comparisons (unsuccessful) ≈ ½ · (1 + 1/(1−λ)²)
    // =========================================================================
    public class LinearProbingHashTable
    {
        private enum SlotState { Empty, Occupied, Deleted }

        private readonly Product?[] _items;
        private readonly SlotState[] _states;
        private int _count;

        public int Capacity => _items.Length;
        public int Count => _count;
        public double LoadFactor => (double)_count / Capacity;

        public LinearProbingHashTable(int capacity)
        {
            if (capacity < 1) throw new ArgumentOutOfRangeException(nameof(capacity));
            _items = new Product?[capacity];
            _states = new SlotState[capacity];
            Array.Fill(_states, SlotState.Empty);
        }

        private int Hash(string barcode)
        {
            unchecked
            {
                int h = 0;
                foreach (char c in barcode)
                    h = h * 31 + c;
                return Math.Abs(h) % Capacity;
            }
        }

        // ── Insert ──────────────────────────────────────────────────────────
        public bool Insert(Product product)
        {
            if (_count >= Capacity)
                throw new InvalidOperationException("Table is full — linear probing requires capacity > n.");

            int idx = Hash(product.Barcode);
            int firstDel = -1;

            for (int i = 0; i < Capacity; i++)
            {
                int slot = (idx + i) % Capacity;
                if (_states[slot] == SlotState.Occupied && _items[slot]!.Barcode == product.Barcode)
                {
                    _items[slot] = product; // update
                    return true;
                }
                if (_states[slot] == SlotState.Deleted && firstDel == -1)
                    firstDel = slot;
                if (_states[slot] == SlotState.Empty)
                {
                    int target = firstDel != -1 ? firstDel : slot;
                    _items[target] = product;
                    _states[target] = SlotState.Occupied;
                    _count++;
                    return true;
                }
            }

            // All slots visited — use first deleted slot if found
            if (firstDel != -1)
            {
                _items[firstDel] = product;
                _states[firstDel] = SlotState.Occupied;
                _count++;
                return true;
            }
            return false;
        }

        // ── Lookup ──────────────────────────────────────────────────────────
        public LookupResult Lookup(string barcode)
        {
            var sw = Stopwatch.StartNew();
            int start = Hash(barcode);
            var steps = new List<string>();
            int compares = 0;

            steps.Add($"Hash(\"{barcode}\") → slot {start}");

            for (int i = 0; i < Capacity; i++)
            {
                int slot = (start + i) % Capacity;

                if (_states[slot] == SlotState.Empty)
                {
                    sw.Stop();
                    steps.Add($"  Slot {slot,3}: EMPTY → stop (not in table)");
                    return new LookupResult
                    {
                        Found = false,
                        Comparisons = compares,
                        ElapsedNs = sw.ElapsedTicks * 1_000_000_000L / Stopwatch.Frequency,
                        Steps = steps
                    };
                }

                if (_states[slot] == SlotState.Deleted)
                {
                    steps.Add($"  Slot {slot,3}: TOMBSTONE → skip, keep probing");
                    continue;
                }

                // Occupied
                compares++;
                if (_items[slot]!.Barcode == barcode)
                {
                    sw.Stop();
                    steps.Add($"  Slot {slot,3}: {_items[slot]!.Barcode} → MATCH ✓  (displaced +{i})");
                    return new LookupResult
                    {
                        Found = true,
                        Item = _items[slot],
                        Comparisons = compares,
                        ElapsedNs = sw.ElapsedTicks * 1_000_000_000L / Stopwatch.Frequency,
                        Steps = steps
                    };
                }

                steps.Add($"  Slot {slot,3}: {_items[slot]!.Barcode} → no match, probe +{i + 1}");
            }

            sw.Stop();
            steps.Add("  Full table scanned → NOT FOUND");
            return new LookupResult
            {
                Found = false,
                Comparisons = compares,
                ElapsedNs = sw.ElapsedTicks * 1_000_000_000L / Stopwatch.Frequency,
                Steps = steps
            };
        }

        // ── Delete (tombstone) ───────────────────────────────────────────────
        public bool Delete(string barcode)
        {
            int start = Hash(barcode);
            for (int i = 0; i < Capacity; i++)
            {
                int slot = (start + i) % Capacity;
                if (_states[slot] == SlotState.Empty) return false;
                if (_states[slot] == SlotState.Occupied && _items[slot]!.Barcode == barcode)
                {
                    _states[slot] = SlotState.Deleted;
                    _items[slot] = null;
                    _count--;
                    return true;
                }
            }
            return false;
        }

        // ── Diagnostics ─────────────────────────────────────────────────────
        public HashTableStats GetStats()
        {
            int maxCluster = 0, curCluster = 0, displaced = 0, empties = 0;
            for (int i = 0; i < Capacity; i++)
            {
                if (_states[i] == SlotState.Occupied)
                {
                    curCluster++;
                    int home = Hash(_items[i]!.Barcode);
                    if (home != i) displaced++;
                    maxCluster = Math.Max(maxCluster, curCluster);
                }
                else
                {
                    if (_states[i] == SlotState.Empty) empties++;
                    curCluster = 0;
                }
            }

            double lf = LoadFactor;
            double tFound = lf < 1 ? 0.5 * (1 + 1.0 / (1 - lf)) : double.PositiveInfinity;
            double tMiss = lf < 1 ? 0.5 * (1 + 1.0 / Math.Pow(1 - lf, 2)) : double.PositiveInfinity;

            return new HashTableStats
            {
                Type = "Linear Probing",
                Capacity = Capacity,
                Count = _count,
                LoadFactor = lf,
                EmptySlots = empties,
                Collisions = displaced,
                MaxCluster = maxCluster,
                AvgChainLength = 0,
                TheoreticalAvgProbesFound = Math.Round(tFound, 3),
                TheoreticalAvgProbesMiss = Math.Round(tMiss, 3)
            };
        }

        public void PrintSlots(int maxSlots = 20)
        {
            Console.WriteLine($"\n  {"IDX",-5} {"STATE",-10} {"BARCODE",-15} {"HOME",-6} {"DISP",-5} PRODUCT");
            Console.WriteLine($"  {new string('─', 80)}");
            int shown = Math.Min(Capacity, maxSlots);
            for (int i = 0; i < shown; i++)
            {
                string state = _states[i] switch
                {
                    SlotState.Empty => "EMPTY",
                    SlotState.Deleted => "DELETED",
                    SlotState.Occupied => "OCCUPIED",
                    _ => "?"
                };
                if (_states[i] == SlotState.Occupied)
                {
                    int home = Hash(_items[i]!.Barcode);
                    int disp = (i - home + Capacity) % Capacity;
                    Console.WriteLine($"  [{i,3}]  {state,-10} {_items[i]!.Barcode,-15} {home,5}  +{disp,-4} {_items[i]!.Name}");
                }
                else
                    Console.WriteLine($"  [{i,3}]  {state,-10}");
            }
            if (shown < Capacity)
                Console.WriteLine($"  ... ({Capacity - shown} more slots not shown)");
        }
    }

    // =========================================================================
    //  Stats DTO
    // =========================================================================
    public class HashTableStats
    {
        public string Type { get; init; } = "";
        public int Capacity { get; init; }
        public int Count { get; init; }
        public double LoadFactor { get; init; }
        public int EmptySlots { get; init; }
        public int Collisions { get; init; }
        public int MaxCluster { get; init; }
        public double AvgChainLength { get; init; }
        public double TheoreticalAvgProbesFound { get; init; }
        public double TheoreticalAvgProbesMiss { get; init; }

        public void Print()
        {
            Console.WriteLine($"  Type                        : {Type}");
            Console.WriteLine($"  Capacity                    : {Capacity}");
            Console.WriteLine($"  Items stored                : {Count}");
            Console.WriteLine($"  Load factor (λ = n/cap)     : {LoadFactor:F3}");
            Console.WriteLine($"  Empty slots                 : {EmptySlots}");
            Console.WriteLine($"  Collisions / Displaced      : {Collisions}");
            Console.WriteLine($"  Max cluster / chain length  : {MaxCluster}");
            Console.WriteLine($"  Theoretical avg probes (hit): {TheoreticalAvgProbesFound}");
            Console.WriteLine($"  Theoretical avg probes (miss): {TheoreticalAvgProbesMiss}");
        }
    }

    // =========================================================================
    //  Benchmark helper — runs many lookups and measures average comparisons
    // =========================================================================
    public static class Benchmark
    {
        public static void Run(
            SeparateChainingHashTable chain,
            LinearProbingHashTable probe,
            List<Product> knownItems,
            List<string> missingBarcodes,
            int trials = 500)
        {
            Console.WriteLine($"\n{'═',1}{'═' + new string('═', 75)}");
            Console.WriteLine("  BENCHMARK — Average comparisons over {0} trials", trials);
            Console.WriteLine($"  {'═' + new string('═', 75)}");

            // Successful lookups
            double chainHitTotal = 0, probeHitTotal = 0;
            for (int t = 0; t < trials; t++)
            {
                var item = knownItems[t % knownItems.Count];
                chainHitTotal += chain.Lookup(item.Barcode).Comparisons;
                probeHitTotal += probe.Lookup(item.Barcode).Comparisons;
            }

            // Unsuccessful lookups
            double chainMissTotal = 0, probeMissTotal = 0;
            for (int t = 0; t < trials; t++)
            {
                var bc = missingBarcodes[t % missingBarcodes.Count];
                chainMissTotal += chain.Lookup(bc).Comparisons;
                probeMissTotal += probe.Lookup(bc).Comparisons;
            }

            double lf = chain.LoadFactor;

            Console.WriteLine($"\n  {"METRIC",-38} {"CHAINING",12} {"PROBING",12}");
            Console.WriteLine($"  {new string('─', 64)}");
            Console.WriteLine($"  {"Load factor (λ)",-38} {lf,12:F3} {lf,12:F3}");
            Console.WriteLine($"  {"Measured avg comparisons (found)",-38} {chainHitTotal / trials,12:F3} {probeHitTotal / trials,12:F3}");
            Console.WriteLine($"  {"Measured avg comparisons (miss)",-38} {chainMissTotal / trials,12:F3} {probeMissTotal / trials,12:F3}");
            Console.WriteLine($"  {"Theoretical avg probes (found)",-38} {chain.GetStats().TheoreticalAvgProbesFound,12:F3} {probe.GetStats().TheoreticalAvgProbesFound,12:F3}");
            Console.WriteLine($"  {"Theoretical avg probes (miss)",-38} {chain.GetStats().TheoreticalAvgProbesMiss,12:F3} {probe.GetStats().TheoreticalAvgProbesMiss,12:F3}");
        }

        // Sweep multiple load factors and print a table
        public static void LoadFactorSweep(List<Product> allProducts)
        {
            Console.WriteLine($"\n{'═',1}{'═' + new string('═', 79)}");
            Console.WriteLine("  LOAD FACTOR SWEEP — Theoretical avg comparisons");
            Console.WriteLine($"  {'═' + new string('═', 79)}");
            Console.WriteLine($"\n  {"λ",6}  {"Chaining Found",16} {"Chaining Miss",14} {"Probing Found",14} {"Probing Miss",13}");
            Console.WriteLine($"  {new string('─', 68)}");

            double[] lfs = { 0.10, 0.25, 0.40, 0.50, 0.60, 0.70, 0.75, 0.80, 0.90, 0.95 };
            foreach (double lf in lfs)
            {
                double cFound = 1 + lf / 2.0;
                double cMiss = lf;
                double pFound = 0.5 * (1 + 1.0 / (1 - lf));
                double pMiss = 0.5 * (1 + 1.0 / Math.Pow(1 - lf, 2));
                string warning = lf >= 0.75 ? "  ⚠" : "";
                Console.WriteLine($"  {lf,6:F2}  {cFound,16:F3} {cMiss,14:F3} {pFound,14:F3} {pMiss,13:F3}{warning}");
            }
            Console.WriteLine("\n  ⚠ = load factor where performance degrades noticeably for linear probing");
        }
    }

