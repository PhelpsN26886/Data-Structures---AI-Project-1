            var missing = new List<string> { "999999999999", "111111111111", "000000000000" };

            // Build both tables
            var chain = new SeparateChainingHashTable(capacity);
            var probe = new LinearProbingHashTable(capacity);
            foreach (var p in products)
            {
                chain.Insert(p);
                probe.Insert(p);
            }

            // Print stats
            Console.WriteLine("\n  ── Separate Chaining Stats ─────────────────────────────────");
            chain.GetStats().Print();
            Console.WriteLine("\n  ── Linear Probing Stats ────────────────────────────────────");
            probe.GetStats().Print();

            // Print first 20 buckets / slots
            Console.WriteLine("\n  ── Chaining Buckets (first 20) ─────────────────────────────");
            chain.PrintBuckets(20);
            Console.WriteLine("\n  ── Probing Slots (first 20) ────────────────────────────────");
            probe.PrintSlots(20);

            // Demonstrate individual lookups
            Console.WriteLine("\n  ── Barcode Lookups ─────────────────────────────────────────");
            foreach (var bc in lookupBarcodes)
            {
                Console.WriteLine($"\n  Scanning barcode: {bc}");
                Console.WriteLine("  [Separate Chaining]");
                var cr = chain.Lookup(bc);
                Console.Write(cr.ToString());
                Console.WriteLine("  [Linear Probing]");
                var pr = probe.Lookup(bc);
                Console.Write(pr.ToString());
            }

            // Benchmark
            Benchmark.Run(chain, probe, products, missing, trials: 500);

            // Demonstrate delete + re-lookup (probing tombstone test)
            if (products.Count > 0)
            {
                var target = products[products.Count / 2];
                Console.WriteLine($"\n  ── Delete Test: remove \"{target.Name}\" ({target.Barcode}) ──");
                bool cd = chain.Delete(target.Barcode);
                bool pd = probe.Delete(target.Barcode);
                Console.WriteLine($"  Chaining delete success : {cd}");
                Console.WriteLine($"  Probing  delete success : {pd}");
                Console.WriteLine("  Re-lookup after delete:");
                var cr2 = chain.Lookup(target.Barcode);
                var pr2 = probe.Lookup(target.Barcode);
                Console.WriteLine($"  Chaining → Found: {cr2.Found}  ({cr2.Comparisons} comparisons)");
                Console.WriteLine($"  Probing  → Found: {pr2.Found}  ({pr2.Comparisons} comparisons)");
            }
        }
    }
