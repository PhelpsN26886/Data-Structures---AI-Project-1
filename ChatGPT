using System;
using System.Collections.Generic;

class Program
{
    static void Main()
    {
        int capacity = 100000;
        int scans = 100000;
        double[] loadFactors = { 0.3, 0.5, 0.7, 0.9 };

        Random rand = new Random();

        foreach (double alpha in loadFactors)
        {
            int itemCount = (int)(capacity * alpha);

            var barcodes = new List<int>();
            var used = new HashSet<int>();

            while (barcodes.Count < itemCount)
            {
                int code = rand.Next(10000000);
                if (used.Add(code))
                    barcodes.Add(code);
            }

            var chaining = new ChainingHashTable(capacity);
            var linear = new LinearProbingHashTable(capacity);

            foreach (var code in barcodes)
            {
                chaining.Insert(code);
                linear.Insert(code);
            }

            int chainProbes = 0;
            int linearProbes = 0;

            for (int i = 0; i < scans; i++)
            {
                int code = barcodes[rand.Next(barcodes.Count)];

                chainProbes += chaining.Search(code);
                linearProbes += linear.Search(code);
            }

            Console.WriteLine("Load Factor: " + alpha);
            Console.WriteLine("Separate Chaining Avg Probes: " + (double)chainProbes / scans);
            Console.WriteLine("Linear Probing Avg Probes: " + (double)linearProbes / scans);
            Console.WriteLine();
        }
    }
}

class ChainingHashTable
{
    private List<int>[] table;
    private int capacity;

    public ChainingHashTable(int capacity)
    {
        this.capacity = capacity;
        table = new List<int>[capacity];

        for (int i = 0; i < capacity; i++)
            table[i] = new List<int>();
    }

    private int Hash(int key)
    {
        return Math.Abs(key.GetHashCode()) % capacity;
    }

    public void Insert(int key)
    {
        int index = Hash(key);
        table[index].Add(key);
    }

    public int Search(int key)
    {
        int index = Hash(key);
        int probes = 0;

        foreach (var item in table[index])
        {
            probes++;
            if (item == key)
                return probes;
        }

        return probes;
    }
}

class LinearProbingHashTable
{
    private int?[] table;
    private int capacity;

    public LinearProbingHashTable(int capacity)
    {
        this.capacity = capacity;
        table = new int?[capacity];
    }

    private int Hash(int key)
    {
        return Math.Abs(key.GetHashCode()) % capacity;
    }

    public void Insert(int key)
    {
        int index = Hash(key);

        while (table[index] != null)
        {
            index = (index + 1) % capacity;
        }

        table[index] = key;
    }

    public int Search(int key)
    {
        int index = Hash(key);
        int probes = 1;

        while (table[index] != null)
        {
            if (table[index] == key)
                return probes;

            index = (index + 1) % capacity;
            probes++;
        }

        return probes;
    }
}
